{
  "name": "workday-daemon",
  "version": "0.2.5",
  "description": "Lightweight activity tracker & timesheet tool",
  "type": "module",
  "bin": {
    "workday": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
