{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "workday",
  "version": "0.2.1",
  "identifier": "com.workday.tray",
  "build": {
    "frontendDist": "../dist/tray-app/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npx ng serve",
    "beforeBuildCommand": "npx ng build"
  },
  "app": {
    "windows": [
      {
        "title": "Workday",
        "label": "main",
        "width": 420,
        "height": 560,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "tooltip": "Workday"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/antontemnov/workday/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEExN0IyNDg5MUQ1NjNFQzUKUldURlBsWWRpU1I3b1J0ZmxpRkJNUlFoNElEV2ZmZ3pxdE5Yc2kydGtWdXl3NFYvV0hWOGVVQmsK"
    }
  }
}
